# Backend
NAT_BACKEND_URL=http://localhost:8000
NAT_CHAT_TIMEOUT_MS=1800000

# Observability
TRACES_PATH=/app/traces/agent_traces.jsonl
# Path to traces directory on the host (mounted into the container as /app/traces)
TRACES_DIR=../traces
OBS_COST_INPUT_PER_1K=0
OBS_COST_OUTPUT_PER_1K=0

# Auth
# In production set AUTH_URL to your public domain: https://your-app.example.com
AUTH_SECRET=replace-with-a-random-secret
AUTH_URL=http://localhost:3000

# Model policy — controls which models are allowed per environment.
# Values: development | staging | production
# Defaults to NODE_ENV if not set.
NEXT_PUBLIC_MODEL_POLICY_ENV=development

# Workspace paths (optional — defaults shown)
# WORKSPACE_ROOT=/app/workspace
# ANALYSIS_ROOT=/tmp/analysis
# USERS_FILE_PATH=data/users.json

# Workspace delete PIN — required to enable the workspace delete confirmation flow.
# Generate with: node -e "const b=require('bcryptjs');b.hash('your-pin',12).then(console.log)"
# Store the bcrypt hash here, never the plaintext PIN.
WORKSPACE_DELETE_PIN_HASH=
