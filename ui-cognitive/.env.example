NAT_BACKEND_URL=http://localhost:8000
NAT_CHAT_TIMEOUT_MS=1800000
TRACES_PATH=/app/traces/agent_traces.jsonl
OBS_COST_INPUT_PER_1K=0
OBS_COST_OUTPUT_PER_1K=0

AUTH_SECRET=replace-with-a-random-secret
AUTH_URL=http://localhost:3000

# Workspace delete PIN — required to enable the workspace delete confirmation flow.
# Generate with: node -e "const b=require('bcryptjs');b.hash('your-pin',12).then(console.log)"
# Store the bcrypt hash here, never the plaintext PIN.
WORKSPACE_DELETE_PIN_HASH=
