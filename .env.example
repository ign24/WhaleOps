NVIDIA_API_KEY=your_nvidia_api_key_here

# Docker socket — ops-agent uses docker.from_env() which reads DOCKER_HOST.
# Leave unset to use the default unix:///var/run/docker.sock.
# When running inside a container, mount /var/run/docker.sock:/var/run/docker.sock.
# DOCKER_HOST=unix:///var/run/docker.sock

# D03 REST API — TBD: architecture decision pending.
# These vars are reserved for a future direct-HTTP integration with D03.
# D03_API_URL=http://your-d03-host:8080
# D03_API_TOKEN=your_d03_api_token_here

MILVUS_URI=http://milvus-standalone:19530
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Redis Stack (recommended for episodic memory + vector search)
# For local docker-compose defaults (no password):
REDIS_URL=redis://redis:6379/0
# If your Redis is password-protected, use:
# REDIS_URL=redis://:your_redis_password@redis:6379/0

# Observability
TRACES_PATH=./traces/agent_traces.jsonl
LOGS_PATH=./logs/agent.log

# SQLite structured memory (instructions, patterns, daily summaries)
NOTES_DB_PATH=/app/data/ops_notes.db

# Telegram webhook gateway
# Token from @BotFather
# TELEGRAM_BOT_TOKEN=123456789:AA...
# Public HTTPS URL that Telegram can reach
# TELEGRAM_WEBHOOK_URL=https://ops-agent.example.com/telegram/webhook
# Comma-separated Telegram chat IDs allowed to use the bot
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
# Shared secret validated from X-Telegram-Bot-Api-Secret-Token header
# TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
