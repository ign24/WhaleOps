NVIDIA_API_KEY=your_nvidia_api_key_here
MILVUS_URI=http://milvus-standalone:19530
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
TAVILY_API_KEY=your_tavily_api_key_here
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_personal_access_token_here
GITHUB_TOKEN=your_github_personal_access_token_here
CONTEXT7_API_KEY=your_context7_api_key_here
SAFETY_MODE=standard - permissive - strict

# Redis Stack (recommended for episodic memory + vector search)
# For local docker-compose defaults (no password):
REDIS_URL=redis://redis:6379/0
# If your Redis is password-protected, use:
# REDIS_URL=redis://:your_redis_password@redis:6379/0

# Observability
TRACES_PATH=./traces/agent_traces.jsonl
LOGS_PATH=./logs/agent.log

# Daily report output
REPORT_OUTPUT_DIR=/app/workspace/reports
